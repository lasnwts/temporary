import software.amazon.awssdk.services.s3.S3Client;
import software.amazon.awssdk.services.s3.model.HeadObjectRequest;
import software.amazon.awssdk.services.s3.model.HeadObjectResponse;
import software.amazon.awssdk.services.s3.model.S3Exception;

public class S3MetadataExample {

    public static void getFileMetadata(S3Client s3Client, String bucketName, String fileName) {
        try {
            // 1. Создаем запрос с именем файла (key) и бакетом
            HeadObjectRequest headObjectRequest = HeadObjectRequest.builder()
                    .bucket(bucketName)
                    .key(fileName)
                    .build();

            // 2. Получаем ответ
            HeadObjectResponse response = s3Client.headObject(headObjectRequest);

            // 3. Извлекаем нужные метаданные
            System.out.println("Размер (байт): " + response.contentLength());
            System.out.println("Тип контента: " + response.contentType());
            System.out.println("ETag: " + response.eTag());
            System.out.println("Дата изменения: " + response.lastModified());
            
            // Пользовательские метаданные (добавленные через x-amz-meta-*)
            if (response.hasMetadata()) {
                System.out.println("Пользовательские метаданные: " + response.metadata());
            }

        } catch (S3Exception e) {
            if (e.statusCode() == 404) {
                System.err.println("Файл не найден: " + fileName);
            } else {
                System.err.println("Ошибка S3: " + e.awsErrorDetails().errorMessage());
            }
        }
    }
}
